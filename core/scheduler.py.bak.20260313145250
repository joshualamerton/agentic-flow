class Workflow:
    """
    Represents a workflow with tasks that can be marked as ready or complete.
    """

    def __init__(self):
        self.tasks = {}

    def add_task(self, name):
        """
        Adds a task to the workflow.

        Args:
            name (str): The name of the task.
        """
        self.tasks[name] = {"ready": False, "task": None}  # Initialize task as not ready

    def ready_tasks(self):
        """
        Returns a list of task names that are ready to be executed.

        Returns:
            list: A list of task names.
        """
        return [name for name, task in self.tasks.items() if task["ready"]]

    def mark_complete(self, task_name):
        """
        Marks a task as complete.

        Args:
            task_name (str): The name of the task to mark as complete.
        """
        self.tasks[task_name]["ready"] = True

    def get_task(self, task_name):
        """
        Returns the task object.

        Args:
            task_name (str): The name of the task.

        Returns:
            dict: The task object.
        """
        return self.tasks[task_name]


